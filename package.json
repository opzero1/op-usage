{
  "name": "op-usage",
  "version": "0.1.0",
  "description": "Codex usage limits beside the OpenCode prompt",
  "type": "module",
  "main": "dist/tui.js",
  "types": "dist/tui.entry.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tui.entry.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.entry.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.mjs && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run scripts/dev-sandbox.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "solid-js": "^1.9.0"
  },
  "peerDependencies": {
    "@opentui/solid": ">=0.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@opentui/core": "0.4.3",
    "@opentui/keymap": "0.4.3",
    "@opentui/solid": "0.4.3",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "opencode": ">=1.17.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opzero1/op-usage.git"
  },
  "license": "MIT",
  "keywords": [
    "opencode",
    "plugin",
    "codex",
    "usage"
  ]
}
